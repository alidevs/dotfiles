# vim:ft=config
theme = Rose Pine
term = xterm-ghostty

selection-background = #232136
selection-foreground = #faf4ed

macos-titlebar-style = hidden
macos-option-as-alt = left

keybind = alt+left=unbind
keybind = alt+right=unbind

bold-is-bright = true
# Keep rounded corners; titlebar is hidden via `macos-titlebar-style = hidden`
# (setting window-decoration = false also removes rounded corners on macOS)
background-opacity = 0.94
background-blur = 40

font-feature = +liga
font-size = 14

cursor-style = block

mouse-hide-while-typing = true

window-padding-color = background
window-padding-x = 10
window-padding-y = 10

cursor-style = block
cursor-style-blink = false

window-padding-x = 10
window-padding-y = 10
window-padding-balance = true
window-padding-color = background

keybind = global:ctrl+shift+x=toggle_quick_terminal
quick-terminal-position = top


clipboard-read = ask
clipboard-write = allow

# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95

# Fix general slowness on hyprland (https://github.com/ghostty-org/ghostty/discussions/3224)
async-backend = epoll
