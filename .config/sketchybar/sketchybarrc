#!/usr/bin/env lua

-- Resolve the local config modules (colors, icons, items.*) regardless of cwd
package.path = package.path
  .. ";" .. os.getenv("HOME") .. "/.config/sketchybar/?.lua"

-- Add the SbarLua module to the package cpath
package.cpath = package.cpath
  .. ";" .. os.getenv("HOME") .. "/.local/share/sketchybar_lua/?.so"

sbar = require("sketchybar")

-- Start the compiled C helper (CPU provider). The colors it color-codes the
-- CPU% with are read via getenv(), so they must be exported here (this mirrors
-- the old colors.sh exports). Kill any previous instance, rebuild, relaunch.
os.execute(
  "export RED=0xffeb6f92 ORANGE=0xffebbcba YELLOW=0xfff6c177 LABEL_COLOR=0xffe0def4; "
  .. "killall helper >/dev/null 2>&1; "
  .. "cd \"$HOME/.config/sketchybar/helper\" && make >/dev/null 2>&1 && "
  .. "(\"$HOME/.config/sketchybar/helper/helper\" git.felix.helper >/dev/null 2>&1 &)"
)

-- Unload the macOS on-screen indicator overlay for volume changes
os.execute(
  "launchctl unload -F /System/Library/LaunchAgents/com.apple.OSDUIHelper.plist "
  .. ">/dev/null 2>&1 &"
)

-- Bundle the entire initial configuration into a single message to sketchybar
-- for drastically faster startup
sbar.begin_config()
require("init")
sbar.hotload(true)
sbar.end_config()

-- Run the event loop (required for Lua callbacks to fire)
sbar.event_loop()
